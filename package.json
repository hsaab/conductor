{
  "name": "conductor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "tsx --env-file=.env src/index.ts",
    "build": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "setup": "node --env-file=.env scripts/setup-new-workspace.mjs",
    "reset-demo": "node --env-file-if-exists=.env scripts/reset-demo.mjs"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.13",
    "@linear/sdk": "^29.0.0",
    "@vercel/functions": "^2.0.0",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "pnpm": {
    "neverBuiltDependencies": ["esbuild", "sqlite3"]
  }
}
