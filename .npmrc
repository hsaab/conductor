# pnpm 9/10 read non-auth settings from .npmrc; pnpm 11 reads only auth/registry
# here and takes everything else from pnpm-workspace.yaml. Build-script gating and
# the verifyDepsBeforeRun mirror therefore live in pnpm-workspace.yaml; this file
# keeps only the pnpm 9/10 form of the deps-check toggle.
#
# verify-deps-before-run=false stops `pnpm <script>` (e.g. `pnpm test`) from
# running an implicit install/deps check first, which aborts the run in CI.
verify-deps-before-run=false
