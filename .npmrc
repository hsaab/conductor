# pnpm config read by every pnpm major (9/10/11). Vercel pins this project to
# pnpm 9.x, which treats a `pnpm-workspace.yaml` as a workspace definition and
# aborts install with "packages field missing or empty" if it lacks a `packages`
# field. We therefore keep pnpm settings here (and in package.json#pnpm) instead
# of a workspace file, since conductor is a single, non-workspace package.
#
# verify-deps-before-run=false stops `pnpm <script>` (e.g. `pnpm test`) from
# running an implicit install/deps check first, which aborts the run in CI.
verify-deps-before-run=false
