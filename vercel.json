{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "node_modules/.pnpm/sqlite3@*/node_modules/sqlite3/**"
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "src/index.ts" }],
  "crons": [{ "path": "/api/reconcile", "schedule": "0 9 * * *" }]
}
